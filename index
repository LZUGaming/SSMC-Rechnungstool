<!DOCTYPE html>
<html lang="de">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>SSMC Rechnungs-Tool</title>
    <script src="https://cdn.tailwindcss.com"></script>
    <style>
        body { background-color: #f3f4f6; }
    </style>
</head>
<body class="p-4 md:p-10">

    <div class="max-w-md mx-auto bg-white rounded-2xl shadow-xl overflow-hidden">
        <div class="p-6">
            <h1 class="text-2xl font-bold text-gray-800 mb-6 text-center">SSMC Rechnungs-Tool</h1>
            
            <div class="space-y-6">
                <!-- Dienstnummer änderbar -->
                <div>
                    <label class="block text-sm font-medium text-gray-700">Dienstnummer (DN)</label>
                    <input type="number" id="dnInput" value="17" class="mt-1 block w-full border border-gray-300 rounded-md p-2 focus:ring-blue-500 focus:border-blue-500">
                </div>

                <!-- Datum Auswahl (wird automatisch auf heute gesetzt) -->
                <div>
                    <label class="block text-sm font-medium text-gray-700">Datum</label>
                    <input type="date" id="dateInput" class="mt-1 block w-full border border-gray-300 rounded-md p-2 focus:ring-blue-500 focus:border-blue-500">
                </div>

                <!-- Auswahl der Dienstleistung -->
                <div>
                    <label class="block text-sm font-medium text-gray-700 mb-2">Was wurde gekauft?</label>
                    <div class="grid grid-cols-1 gap-2" id="serviceOptions">
                        <button onclick="updateOutput('Behandlung')" class="service-btn w-full text-left p-3 rounded-lg border border-gray-200 hover:bg-blue-50 transition">Behandlung</button>
                        <button onclick="updateOutput('Krankenversicherung')" class="service-btn w-full text-left p-3 rounded-lg border border-gray-200 hover:bg-blue-50 transition">Krankenversicherung</button>
                        <button onclick="updateOutput('Erste-Hilfe-Schein')" class="service-btn w-full text-left p-3 rounded-lg border border-gray-200 hover:bg-blue-50 transition">Erste-Hilfe-Schein</button>
                        <button onclick="updateOutput('Medkit-Schein')" class="service-btn w-full text-left p-3 rounded-lg border border-gray-200 hover:bg-blue-50 transition">Medkit-Schein</button>
                    </div>
                </div>

                <!-- Ergebnis Bereich -->
                <div class="pt-4 border-t border-gray-100">
                    <label class="block text-sm font-medium text-gray-700 mb-1">Resultat:</label>
                    <div class="flex gap-2">
                        <input type="text" id="outputField" readonly class="flex-1 p-3 bg-gray-50 border rounded-md font-mono text-sm text-gray-800">
                        <button onclick="copyToClipboard()" class="bg-blue-600 text-white px-4 py-2 rounded-md hover:bg-blue-700">Kopieren</button>
                    </div>
                </div>
            </div>
        </div>
    </div>

    <script>
        const dateInput = document.getElementById('dateInput');
        const outputField = document.getElementById('outputField');
        const dnInput = document.getElementById('dnInput');

        // Setze Datum auf das aktuelle Echtzeit-Datum
        function setCurrentDate() {
            const today = new Date().toISOString().split('T')[0];
            dateInput.value = today;
        }

        // Initial beim Laden setzen
        window.onload = setCurrentDate;

        function formatDate(dateStr) {
            const [year, month, day] = dateStr.split('-');
            return `${day}.${month}.${year}`;
        }

        function updateOutput(service) {
            const dienstNummer = dnInput.value || "00";
            // Nutze den aktuell im Input stehenden Wert (der automatisch heute ist)
            const formattedDate = formatDate(dateInput.value);
            const result = `SSMC ${dienstNummer} x ${formattedDate} ${service}`;
            outputField.value = result;

            document.querySelectorAll('.service-btn').forEach(btn => {
                btn.classList.remove('bg-blue-100', 'border-blue-500');
                if (btn.innerText === service) {
                    btn.classList.add('bg-blue-100', 'border-blue-500');
                }
            });
        }

        function copyToClipboard() {
            if (!outputField.value) return;
            outputField.select();
            document.execCommand('copy');
            // Kein Alert, um den Workflow nicht zu unterbrechen
        }
    </script>
</body>
</html>
